{
  "name": "skyourtest",
  "version": "3.0.0",
  "description": "SkyourTest - Professional QC Automation Testing Platform for any website with detailed Excel reports",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev -- --host",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "pdfkit": "^0.19.1",
    "playwright": "^1.42.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
